# ─────────────────────────────────────────────────
# Supabase — nuevo modelo de API
# ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxx   # public key — seguro en browser
SUPABASE_SECRET_KEY=sb_secret_xxxx                  # secret key — NUNCA al browser

# Scripts Python (ETL) también usan la secret key:
SUPABASE_URL=https://xxxx.supabase.co               # alias para supabase_client.py
SUPABASE_SERVICE_KEY=sb_secret_xxxx                 # alias para supabase_client.py

# ─────────────────────────────────────────────────
# Azure AD — SSO con Supabase

# ─────────────────────────────────────────────────
AZURE_TENANT_ID=xxxx
AZURE_CLIENT_ID=xxxx
AZURE_CLIENT_SECRET=xxxx

# ─────────────────────────────────────────────────
# ClickUp sync (22_clickup_sync.py / 23_apply_clickup_pending.py)
# ─────────────────────────────────────────────────
CLICKUP_API_TOKEN=pk_xxxx               # también acepta CLICKUP_TOKEN como alias
CLICKUP_LIST_PROD_ACTIVA=xxxxxxxx   # lista "Producción Activa" (constante, override opcional)

# ─────────────────────────────────────────────────
# Teams / SharePoint (notificaciones opcionales)
# ─────────────────────────────────────────────────
TEAMS_WEBHOOK_URL=https://...
SHAREPOINT_SITE_ID=xxxx
SHAREPOINT_DRIVE_ID=xxxx
SHAREPOINT_FOLDER_PATH=/file/path

# ─────────────────────────────────────────────────
# Cache invalidation — endpoint POST /api/revalidate
# El ETL lo llama con header x-revalidate-secret para invalidar el cache
# de produccion tras un sync. Generar con: openssl rand -hex 32
# ─────────────────────────────────────────────────
REVALIDATE_SECRET=xxxx

# ─────────────────────────────────────────────────
# Sentry (Sprint 0.9)
# ─────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# ─────────────────────────────────────────────────
# Metabase (post iter-1)
# ─────────────────────────────────────────────────
METABASE_URL=http://localhost:3001
METABASE_SECRET_KEY=xxxx
